{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Hugo: dev server",
      "type": "shell",
      "command": "bash ./prepare-static-assets.sh && hugo server -D --disableFastRender",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Hugo: build",
      "type": "shell",
      "command": "bash ./prepare-static-assets.sh && hugo --gc --minify",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Hugo: clean generated files",
      "type": "shell",
      "command": "rm -rf public resources/_gen .hugo_build.lock",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
